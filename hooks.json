{
  "description": "Teneb — token-reduction hooks for Claude Code (compaction, prompt guard, budget tracking, next-step recommendations)",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PLUGIN_ROOT\"/.claude/hooks/session-start.js", "timeout": 5 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PLUGIN_ROOT\"/.claude/hooks/prompt-submit.js", "timeout": 5 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PLUGIN_ROOT\"/.claude/hooks/pre-tool-use.js", "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PLUGIN_ROOT\"/.claude/hooks/post-tool-use.js", "timeout": 5 }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PLUGIN_ROOT\"/.claude/hooks/pre-compact.js", "timeout": 5 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PLUGIN_ROOT\"/.claude/hooks/stop.js", "timeout": 5 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PLUGIN_ROOT\"/.claude/hooks/session-end.js", "timeout": 5 }
        ]
      }
    ]
  }
}
